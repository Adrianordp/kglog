#!/bin/bash
# This script is used to start the application in either development or
# production mode.

usage() {
    echo "Usage: $0 [--dev|--prod] [--build]"
    echo "  --dev    Start the application in development mode"
    echo "  --prod   Start the application in production mode"
    echo "  --build  Build Docker images before starting"
}

MODE=""
BUILD=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dev)
            MODE="dev"
            ;;
        --prod)
            MODE="prod"
            ;;
        --build)
            BUILD=true
            ;;
        --help)
            usage
            exit 0
            ;;
        *)
            echo "Invalid option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
    shift
done

if [[ -z "$MODE" ]]; then
    echo "Error: must specify --dev or --prod." >&2
    usage >&2
    exit 1
fi

if [[ "$BUILD" == true ]]; then
    echo "Building Docker images..."
    docker compose -f docker-compose.yml -f docker-compose.$MODE.yml up -d --build
else
    echo "Starting Docker containers..."
    docker compose -f docker-compose.yml -f docker-compose.$MODE.yml up -d
fi


